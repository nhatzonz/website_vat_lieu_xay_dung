# URL gốc của site (dùng cho canonical, sitemap, og:url). Không có dấu / cuối.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL API NestJS mà server components fetch tới (gọi phía server).
# Production nên trỏ tới địa chỉ nội bộ, ví dụ http://api:4000/api
API_BASE_URL=http://localhost:4000/api

# (Tùy chọn) URL API public cho code chạy phía client, nếu cần.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
