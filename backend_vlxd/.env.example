# ===== App =====
NODE_ENV=development
PORT=4000
# Tiền tố toàn cục cho API, ví dụ: /api/public/... và /api/admin/...
API_PREFIX=api
# Cho phép CORS từ frontend (phân tách bằng dấu phẩy)
CORS_ORIGINS=http://localhost:3000

# ===== Database (MySQL) =====
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=ceiling_db
# Bật log truy vấn SQL khi debug
DB_LOGGING=false

# ===== JWT (admin auth) =====
JWT_SECRET=thay-bang-chuoi-bi-mat-dai-ngau-nhien
JWT_EXPIRES_IN=1d

# ===== Cloudinary (upload ảnh — dùng khi làm module upload) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Rate limit =====
THROTTLE_TTL=60
THROTTLE_LIMIT=120
